# Example environment configuration
# Copy this file to .env and fill in the values.

# Server
PORT=3000
NODE_ENV=development

# Database
MONGO_URI=mongodb://<username>:<password>@host:port/dbname

# Email (SMTP)
SMTP_HOST=
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Ingenium Website <noreply@example.com>"

# Frontend origin for CORS
CLIENT_URL=http://localhost:3000

# NOTE: this project no longer uses reCAPTCHA; any related variables have been removed.
